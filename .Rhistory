mann.whitney.normal <- function(ranksum,m,n){
ew <- (m*(m+n+1))/2
vw <- (m*n*(m+n+1))/24
z <- round((ranksum+0.5-ew)/((vw^0.5)),2)
}
mann.whitney.normal(ranksum=396.5,m=21,n=27)
mann.whitney.normal <- function(ranksum,m,n){
ew <- (m*(m+n+1))/2
vw <- (m*n*(m+n+1))/24
z <- round((ranksum+0.5-ew)/((vw^0.5)),2)
print(z)
}
mann.whitney.normal(ranksum=396.5,m=21,n=27)
