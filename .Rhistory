mann.whitney.rank.sum <- function(data1,data2){
if (length(data1)==length(data2)){}
}
mann.whitney.rank.sum <- function(data1,data2){
if (length(data1)==length(data2)){
small <- data1
large <- data2
}
if (length(data1)>length(data2)){
small <- data2
large <- data1
}
if (length(data1)<length(data2)){
small <- data1
large <- data2
}
ranksum <- min(sum(rank(c(small,large))[1:length(small)]),sum(rank(c(-small,-large))[1:length(small)]))
print(ranksum)
}
mann.whitney.rank.sum(c(1,2,3,4,5),c(2,3,4,5))
