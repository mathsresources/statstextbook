sums <- function(dfr){
attach(dfr)
sxx <- sum(x^2) - ((sum(x))^2)/length(x)
syy <- sum(y) - ((sum(y))^2)/length(y)
sxy <- sum(x*y) - (sum(x)*sum(y))/length(x)
print(sxx)
print(syy)
print(sxy)
detach(dfr)
}
sums(df_stoppingdatat)
sums <- function(dfr){
attach(dfr)
sxx <- sum(x^2) - ((sum(x))^2)/length(x)
syy <- sum(y^2) - ((sum(y))^2)/length(y)
sxy <- sum(x*y) - (sum(x)*sum(y))/length(x)
print(sxx)
print(syy)
print(sxy)
detach(dfr)
}
sums(df_stoppingdatat)
cor.test(df_stoppingdatat$x,df_stoppingdatat$sqrty)
