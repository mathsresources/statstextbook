xi <- rtruncnorm(12,0,30,20,5)
e <- rtruncnorm(12,-10,10,0,2)
a<- 3
b<- 0.7
y<- ceiling(a+ b*xi+e)
x<-ceiling(xi)
plot(x,y)
df_french <- data.frame(x,y)
cor(x,y)
summary(lm(y~x))
