x <- 1:25
y <- 7 + 2*x + rnorm(25, 0, 5)
plot(x,y)
fit <- lm(y~x)
tmp <- predict(fit, data.frame(x=1:25), interval='prediction')
means <- sapply( 1:25, function(x){
y <- rnorm(10000, 7+2*x, 5)
mean( tmp[x,2] <= y & y <= tmp[x,3] )
})
mean(means)
