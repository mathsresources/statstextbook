library(truncnorm)
x <- rtruncnorm(12,0,30,20,5)
e <- rtruncnorm(12,-10,10,0,2)
a<- 3
b<- 0.7
y<- ceiling(a+ b*x+e)
plot(x,y)
df_french <- data.frame(x,y)
cor(x,y)
summary(lm(y~x))
