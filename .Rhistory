install.packages("truncnorm")
library(truncnorm)
x<-rtruncnorm(100,0.1,4.9,2.5,0.8)
alpha=1.5
beta=0.3
err<-rtruncnorm(100,-1.4,1.4,0,0.5)
y<-alpha+beta*x+err
df<-data.frame(x,y)
plot(x,y)
summary(lm(y~x))
