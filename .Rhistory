pilm <- lm(y~x)
predict(pilm, newdata = 0.1, interval = 'confidence')
pidt <- data.frame(x=0.1)
predict(pilm, newdata = pidt, interval = 'confidence')
pidt <- data.frame(x=c(0.1,1,2,3,4,4.8))
predict(pilm, newdata = pidt, interval = 'confidence')
pidt <- data.frame(x=0.9)
predict(pilm, newdata = pidt, interval = 'confidence')
pidt <- data.frame(x=c(0.85,0.95))
predict(pilm, newdata = pidt, interval = 'confidence')
pidt <- data.frame(x=c(0.87,0.93))
predict(pilm, newdata = pidt, interval = 'confidence')
pidt <- data.frame(x=c(0.1,1,2,3,4,4.8))
predict(pilm, newdata = pidt, interval = 'predict')
pidt <- data.frame(x=c(0.87,0.93))
pidt <- data.frame(x=c(0.87,0.9,0.93))
predict(pilm, newdata = pidt, interval = 'predict')
